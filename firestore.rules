rules_version = '2';

// Toda la lectura/escritura pasa por el backend (soy612_cloud) usando el SDK
// de administración de Firebase, que ignora estas reglas por diseño. Aquí se
// niega explícitamente cualquier acceso directo desde clientes (app/web).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
