# Puerto de escucha. Cloud Run lo inyecta automáticamente; solo se usa en local.
PORT=8080

# Orígenes permitidos por CORS, separados por coma.
CORS_ORIGIN=https://soy612.click,http://localhost:48371

# GCP project ID (Firestore/Auth/Storage). En Cloud Run se infiere solo; en
# local, exporta esta variable o usa `gcloud config set project soy612`.
GOOGLE_CLOUD_PROJECT=soy612

# Opcional: solo para entornos locales SIN `gcloud auth application-default login`.
# Pega aquí el contenido completo (JSON) de una llave de cuenta de servicio.
# NUNCA subir un valor real de esta variable a git.
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account", ...}
